{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Special Organizer",
  "version": "0.1.0",
  "identifier": "com.specialorganizer.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Special Organizer",
        "width": 1280,
        "height": 820,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "publisher": "Special Organizer Contributors",
    "category": "Productivity",
    "icon": ["icons/icon.ico"],
    "shortDescription": "Local-first special-series lifecycle manager",
    "longDescription": "Special Organizer is a local-first Windows desktop application for managing supermarket special-series lifecycle work.",
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false,
        "languages": ["English", "SimpChinese"],
        "compression": "lzma",
        "startMenuFolder": "Special Organizer"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "REPLACE_WITH_TAURI_UPDATER_PUBLIC_KEY",
      "endpoints": [
        "https://github.com/charleshuang337/special-organizer/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "basicUi"
      }
    }
  }
}
